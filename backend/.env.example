PORT=3001

# Postgres — this project's own bundled container (see docker-compose.yml)
PGHOST=localhost
PGPORT=55432
PGDATABASE=kdbs2

# App runtime: limited, non-superuser role.
PGUSER=burza_app
PGPASSWORD=burza_app_pw

# Migrations only (npm run db:reset): superuser, must match docker-compose POSTGRES_USER/PASSWORD.
PGADMINUSER=postgres
PGADMINPASSWORD=postgres

CORS_ORIGIN=http://localhost:5173
